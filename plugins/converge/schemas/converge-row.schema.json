{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.codex/converge/schemas/converge-row.schema.json",
  "title": "Converge Row",
  "description": "Portable target/probe/evidence/repair row emitted by any Converge adapter.",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "target_id",
    "class",
    "evidence",
    "next_action"
  ],
  "properties": {
    "target_id": {
      "type": "string",
      "minLength": 1
    },
    "target": {
      "description": "Expected value, state, threshold, maturity stage, or behavior."
    },
    "probe": {
      "description": "Observed value from implementation, test, query, UI, API, or evidence."
    },
    "delta": {
      "description": "Difference, transition, gap, or mismatch between probe and target."
    },
    "class": {
      "type": "string",
      "enum": [
        "match",
        "rounding",
        "pass",
        "pass_real_surface",
        "pass_controlled_harness",
        "pass_with_bypass",
        "miss_small",
        "miss_large",
        "fail",
        "missing",
        "blocked",
        "drift",
        "regression",
        "skip"
      ]
    },
    "evidence": {
      "description": "Literal proof, command output, artifact path, URL, or reviewed note.",
      "oneOf": [
        { "type": "string" },
        {
          "type": "array",
          "items": { "type": "string" }
        }
      ]
    },
    "next_action": {
      "type": "string"
    },
    "adapter": {
      "type": "string"
    },
    "convergence_style": {
      "type": "string"
    },
    "required": {
      "type": "boolean"
    },
    "weight": {
      "type": "number",
      "exclusiveMinimum": 0
    },
    "tolerance": {
      "type": "number",
      "minimum": 0
    },
    "evidence_as_of": {
      "type": "string"
    },
    "proof_envelope": {
      "description": "Context that bounds what a passing proof actually proves.",
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "environment": {
          "type": "string"
        },
        "surface": {
          "type": "string"
        },
        "proof_id": {
          "type": "string"
        },
        "captured_at": {
          "type": "string"
        },
        "freshness_days": {
          "type": "integer",
          "minimum": 0
        },
        "external_dependencies": {
          "type": "array",
          "items": { "type": "string" }
        },
        "bypassed_controls": {
          "type": "array",
          "items": { "type": "string" }
        },
        "side_effects": {
          "type": "array",
          "items": { "type": "string" }
        },
        "fails_to_test": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "bypassed_controls": {
      "description": "Shortcut for controls disabled, mocked, skipped, or auto-satisfied for this proof.",
      "type": "array",
      "items": { "type": "string" }
    },
    "fails_to_test": {
      "description": "Negative-space claims this proof does not establish.",
      "type": "array",
      "items": { "type": "string" }
    },
    "side_effects": {
      "description": "Control-plane, data-plane, or fixture mutations caused by the proof run.",
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
