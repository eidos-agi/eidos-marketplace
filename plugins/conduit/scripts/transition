#!/usr/bin/env bash
#
# transition — keep moving stuff from this Mac to the Mac mini over SSH.
#
# Thin wrapper over `conduit sync` (the machine-conduit registry/proof layer).
# Daniel calls this activity "transition"; the plugin underneath is `conduit`.
#
# Usage:
#   transition PATH [PATH...]        Sync each path to ~/transition-inbox/ on the Mac mini
#   transition --manifest            Sync every "src :: dest" line in the manifest
#   transition --dry-run PATH        Preview without copying (passthrough to conduit/rsync)
#   transition --dest DIR PATH       Override remote destination dir (relative to remote home)
#   transition --target ID PATH      Override machine (default: mac-mini-01)
#   transition --list                Show the manifest and resolved target
#
# Notes:
#   - Non-destructive: rsync without --delete. Re-runs only send changed bytes.
#   - Manifest:  $HOME/.config/transition/manifest.txt
#                one entry per line:  /abs/source/path :: remote/dest/dir/
#                blank lines and lines starting with # are ignored.
set -euo pipefail

CONDUIT="${CONDUIT_BIN:-$HOME/plugins/conduit/scripts/conduit}"
MANIFEST="${TRANSITION_MANIFEST:-$HOME/.config/transition/manifest.txt}"
TARGET="mac-mini-01"
# Personal home on the mini = the 2.7 TiB external drive (APFS), not the full internal SSD.
DEST_DEFAULT="${TRANSITION_DEST:-/Volumes/MacMiniStorage/personal/}"
DRY=""
USE_MANIFEST=0
PATHS=()

die() { echo "transition: $*" >&2; exit 1; }

[[ -x "$CONDUIT" ]] || die "conduit CLI not found at $CONDUIT (set CONDUIT_BIN)"

DEST_OVERRIDE=""
while [[ $# -gt 0 ]]; do
  case "$1" in
    --dry-run) DRY="--dry-run"; shift ;;
    --manifest) USE_MANIFEST=1; shift ;;
    --dest) DEST_OVERRIDE="${2:?--dest needs a value}"; shift 2 ;;
    --target) TARGET="${2:?--target needs a value}"; shift 2 ;;
    --list)
      echo "target:   $TARGET"
      echo "manifest: $MANIFEST"
      [[ -f "$MANIFEST" ]] && { echo "--- entries ---"; grep -vE '^\s*(#|$)' "$MANIFEST" || true; } || echo "(no manifest yet)"
      exit 0 ;;
    -h|--help) sed -n '2,28p' "$0" | sed 's/^# \{0,1\}//'; exit 0 ;;
    --*) die "unknown flag: $1" ;;
    *) PATHS+=("$1"); shift ;;
  esac
done

sync_one() {  # $1=source  $2=dest
  local src="$1" dst="$2"
  echo ">> transition: $src  ->  $TARGET:$dst"
  "$CONDUIT" sync $DRY "$src" "$dst" --target "$TARGET"
}

if [[ "$USE_MANIFEST" -eq 1 ]]; then
  [[ -f "$MANIFEST" ]] || die "no manifest at $MANIFEST (create it, one 'src :: dest' per line)"
  while IFS= read -r line; do
    [[ -z "${line// }" || "${line#\#}" != "$line" ]] && continue
    src="${line%% :: *}"; dst="${line##* :: }"
    [[ "$src" == "$line" ]] && die "manifest line missing ' :: ' separator: $line"
    src="${src/#\~/$HOME}"
    sync_one "$src" "$dst"
  done < "$MANIFEST"
  exit 0
fi

[[ ${#PATHS[@]} -gt 0 ]] || die "nothing to move — pass PATH(s) or --manifest (see --help)"
DEST="${DEST_OVERRIDE:-$DEST_DEFAULT}"
for p in "${PATHS[@]}"; do
  sync_one "${p/#\~/$HOME}" "$DEST"
done
