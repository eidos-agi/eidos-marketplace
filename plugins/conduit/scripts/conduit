#!/usr/bin/env bash
set -euo pipefail

script_dir="$(cd "$(dirname "$0")" && pwd)"

is_python_311_or_newer() {
  local python_bin="$1"

  "$python_bin" -c 'import sys; raise SystemExit(0 if sys.version_info >= (3, 11) else 1)' >/dev/null 2>&1
}

candidate_pythons=()
if [[ -n "${CONDUIT_PYTHON:-}" ]]; then
  candidate_pythons+=("$CONDUIT_PYTHON")
fi
candidate_pythons+=(
  /Users/dshanklin/.local/bin/python3.14
  /Users/dshanklin/.local/bin/python3.13
  /Users/dshanklin/.local/bin/python3.12
  /Users/dshanklin/.local/bin/python3.11
  python3.14
  python3.13
  python3.12
  python3.11
  /opt/homebrew/bin/python3
  /opt/homebrew/bin/python3.14
  /opt/homebrew/bin/python3.13
  /opt/homebrew/bin/python3.12
  /opt/homebrew/bin/python3.11
  python3
)

for python_bin in "${candidate_pythons[@]}"; do
  if [[ "$python_bin" == /* ]]; then
    if [[ -x "$python_bin" ]]; then
      exec "$python_bin" "$script_dir/conduit.py" "$@"
    fi
  elif command -v "$python_bin" >/dev/null 2>&1 && is_python_311_or_newer "$python_bin"; then
    exec "$python_bin" "$script_dir/conduit.py" "$@"
  fi
done

echo "conduit requires Python 3.11+ with tomllib; set CONDUIT_PYTHON to a compatible interpreter." >&2
exit 1
