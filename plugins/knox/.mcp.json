{
  "mcpServers": {
    "knox": {
      "command": "python3",
      "args": [
        "${CLAUDE_PLUGIN_ROOT}/scripts/knox/bootstrap.py"
      ],
      "env": {
        "PYTHONPATH": "${CLAUDE_PLUGIN_ROOT}",
        "KNOX_APPROVAL_MODE": "code",
        "KNOX_APPROVAL_TIMEOUT_SECONDS": "90",
        "KNOX_REQUIRE_PAIRING": "1"
      }
    }
  }
}
